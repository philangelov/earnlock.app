# Frontend environment. Copy to `.env` — Expo loads EXPO_PUBLIC_* into the client bundle.
# Anything here is readable in the shipped app, so it must contain no secrets.
# OAuth client IDs are public identifiers by design; the Supabase anon key is NOT here
# on purpose (the backend holds it and performs the token exchange).

# Backend origin. On a device build, `localhost` resolves to the phone; in development the
# app rewrites it to the LAN address Expo serves Metro from (see src/lib/api.ts).
EXPO_PUBLIC_API_URL=http://localhost:5000

# Sign in with Google. Create an iOS OAuth client and a Web OAuth client in Google Cloud,
# then register BOTH under Supabase → Authentication → Providers → Google → Client IDs
# (web first), and enable "Skip nonce check".
# Without these the Google button disables itself and the config plugin is skipped.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Apple Screen Time (Family Controls). Defaults to this repo's Apple account.
# EXPO_APPLE_TEAM_ID=ZMJTV28224
# EXPO_APP_GROUP=group.com.filipangelov.earnlock
