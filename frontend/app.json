{
  "expo": {
    "name": "EarnLock",
    "slug": "earnlock.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/Icon-iOS-Default-1024x1024@1x.png",
    "scheme": "earnlockapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/Icon-iOS-Default-1024x1024@1x.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f4f5f7",
          "image": "./assets/splash-icon-light.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/splash-icon-dark.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.filipangelov.earnlock",
      "icon": {
        "light": "./assets/icons/Icon-iOS-Default-1024x1024@1x.png",
        "dark": "./assets/icons/Icon-iOS-Dark-1024x1024@1x.png",
        "tinted": "./assets/icons/Icon-iOS-ClearDark-1024x1024@1x.png"
      }
    },
    "extra": {
      "apiUrl": "http://localhost:5000"
    }
  }
}
