FLASK_ENV=development
# Project Settings > API > Project URL. JWTs are verified against this project's JWKS
# endpoint (${SUPABASE_URL}/auth/v1/.well-known/jwks.json) — no shared secret needed.
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings > API > anon/public key (safe for the backend to hold; register/login
# are performed server-side so this never reaches the client)
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
