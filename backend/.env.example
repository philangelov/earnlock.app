FLASK_ENV=development

SUPABASE_URL=https://your-project-ref.supabase.co/

SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-only (SECRET): service_role key from Supabase → Project Settings → API.
# Required by the quiz engine to write the authoritative screen-time currency (bypasses RLS).
# Never expose this to the mobile client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Server-only (SECRET): Anthropic API key for AI quiz generation + remediation.
# Get it from console.anthropic.com. Never expose this to the mobile client.
# If unset, generation falls back to the offline question bank (no AI, still works).
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Generation model. Default is cost-effective for structured MCQ; bump for quality.
# One of: claude-haiku-4-5 | claude-sonnet-5 | claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# Max characters of imported study text kept per material (POST /knowledge/import).
# KNOWLEDGE_MAX_CHARS=12000

# Quiz reward rules (optional overrides; defaults match architecture.md §8)
# QUIZ_CORRECT_TARGET=5
# REWARD_SECONDS=900
# QUIZ_LEN_NORMAL=5
# QUIZ_LEN_DEBT=7
